{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "up", "legendFormat": "{{ job }}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "{{ job }} {{ method }} {{ status }}" }]
    },
    {
      "title": "Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{ job }}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])", "legendFormat": "{{ job }}" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "rate(process_cpu_seconds_total[5m]) * 100", "legendFormat": "{{ job }}" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "{{ job }}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "Active Connections" }]
    },
    {
      "title": "Redis Memory",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [{ "expr": "redis_memory_used_bytes / redis_memory_max_bytes", "legendFormat": "Memory Usage" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } } }
    },
    {
      "title": "Container Restarts",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [{ "expr": "increase(container_restart_count[1h])", "legendFormat": "{{ name }}" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["algo-arena"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AlgoArena Overview",
  "uid": "algo-arena-overview",
  "version": 1
}
