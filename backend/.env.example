# ===========================================
# 数据库配置
# ===========================================

# PostgreSQL 连接字符串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/algo_oj?schema=public"

# PostgreSQL 直连 URL (用于迁移操作)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/algo_oj?schema=public"

# PostgreSQL 超级用户 (用于创建数据库)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=algo_oj
POSTGRES_PORT=5432

# ===========================================
# Redis 配置
# ===========================================

REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# ===========================================
# 应用配置
# ===========================================

# 服务器端口
PORT=3001

# JWT 密钥 (生产环境请更换)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 环境: development | production | test
NODE_ENV="development"

# 日志级别: error | warn | info | debug
LOG_LEVEL="info"

# ===========================================
# 数据库备份配置
# ===========================================

# 备份目录
BACKUP_DIR="./backups"

# 备份保留天数
BACKUP_RETENTION_DAYS=30
