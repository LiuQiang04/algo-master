{
  "name": "algo-arena",
  "version": "1.0.0",
  "private": true,
  "description": "Algorithm Competition Learning Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "db:generate": "cd server && npx prisma generate",
    "db:push": "cd server && npx prisma db push",
    "db:migrate": "cd server && npx prisma migrate dev",
    "db:seed": "cd server && npx ts-node prisma/seed.ts",
    "test:server": "cd server && npm test",
    "test:client": "cd frontend && npm test",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:all": "npm run test:server && npm run test:client && npm run test:e2e"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@playwright/test": "^1.42.0"
  }
}
