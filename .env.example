# ============================================================
# AlgoArena Environment Configuration
# Copy this file to .env and update the values
# ============================================================

# ==================== Database ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=algo_arena
POSTGRES_PORT=5432

# ==================== Redis ====================
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379

# ==================== Application ====================
JWT_SECRET=generate-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
NODE_ENV=production
LOG_LEVEL=info

# ==================== CORS ====================
CORS_ORIGIN=https://your-domain.com

# ==================== Ports ====================
FRONTEND_PORT=80
BACKEND_PORT=3000
SERVER_PORT=3001

# ==================== Replicas ====================
BACKEND_REPLICAS=2
SERVER_REPLICAS=2
